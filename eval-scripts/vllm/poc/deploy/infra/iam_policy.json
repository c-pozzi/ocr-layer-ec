{
  "Description": "IAM policies for the OCR pipeline. Create two roles: one for Lambda, one for EC2.",

  "LambdaExecutionRole": {
    "RoleName": "ocr-pipeline-lambda-role",
    "PolicyDocument": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "StartPipelineInstance",
          "Effect": "Allow",
          "Action": ["ec2:StartInstances", "ec2:DescribeInstances"],
          "Resource": "arn:aws:ec2:REGION:ACCOUNT:instance/INSTANCE_ID"
        },
        {
          "Sid": "CheckInputBucket",
          "Effect": "Allow",
          "Action": ["s3:ListBucket"],
          "Resource": "arn:aws:s3:::ocr-pipeline-bucket"
        },
        {
          "Sid": "CloudWatchLogs",
          "Effect": "Allow",
          "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
          "Resource": "arn:aws:logs:*:*:*"
        }
      ]
    }
  },

  "EC2InstanceRole": {
    "RoleName": "ocr-pipeline-ec2-role",
    "PolicyDocument": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "S3ReadWritePipelineBucket",
          "Effect": "Allow",
          "Action": [
            "s3:GetObject",
            "s3:PutObject",
            "s3:DeleteObject",
            "s3:ListBucket"
          ],
          "Resource": [
            "arn:aws:s3:::ocr-pipeline-bucket",
            "arn:aws:s3:::ocr-pipeline-bucket/*"
          ]
        },
        {
          "Sid": "SelfStop",
          "Effect": "Allow",
          "Action": ["ec2:StopInstances"],
          "Resource": "arn:aws:ec2:REGION:ACCOUNT:instance/INSTANCE_ID",
          "Condition": {
            "StringEquals": {
              "ec2:ResourceTag/Name": "ocr-pipeline"
            }
          }
        }
      ]
    }
  }
}
